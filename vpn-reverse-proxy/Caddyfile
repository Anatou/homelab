(generic-log) {
	log {
		output file
		filename "/var/log/caddy.log"
		roll_local_time true
	}
}

*.{$DOMAIN}:{$FIREWALL_VPN_INPUT_PORTS} {
	tls {
		dns desec {
			token "{$DESEC_TOKEN}"
		}
	}

	@foo host foo.{$DOMAIN}
	handle @foo {
		respond "Foo!" 200 {
			close
		}
		import generic-log
	}

	@homepage host homepage.{$DOMAIN}
	handle @homepage {
		reverse_proxy {$HOMEPAGE_IP}:{$HOMEPAGE_PORT}
		import generic-log
	}

	handle {
		abort
	}
}



#{$DOMAIN}/route:port {
	#redir /homepage /homepage/
#	reverse_proxy ip:port
#	import glog
#}